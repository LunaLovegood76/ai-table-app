<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>HappyDuck AI 像玩游戏一样学习钉钉AI表格</title>
  <link rel="icon" type="image/png" href="favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <script src="js/lucide.min.js"></script>
  <link rel="stylesheet" href="css/style.css?v=2">
  <style>
    /* ====== 新版开屏页样式 ====== */
    .splash-screen {
      position: fixed;
      inset: 0;
      z-index: 9999;
      width: 100vw;
      height: 100vh;
      overflow: hidden;
      background: #FFD700;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .splash-screen.fade-out {
      opacity: 0;
      transform: scale(1.05);
      pointer-events: none;
    }
    /* 渐变背景 */
    .bg {
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse at 40% 30%, #FFE566 0%, #FFD700 45%, #FFAA00 100%);
    z-index: 0;
    }

    /* 背景波纹圈 */
    .ripple {
    position: fixed;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.25);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    animation: rippleOut 3s ease-out infinite;
    }
    .ripple:nth-child(2) { animation-delay: 1s; }
    .ripple:nth-child(3) { animation-delay: 2s; }

    @keyframes rippleOut {
    0%   { transform: translate(-50%, -50%) scale(0); opacity: 0.6; }
    100% { transform: translate(-50%, -50%) scale(1.8); opacity: 0; }
    }

    /* 浮动气泡 */
    .bubble {
    position: fixed;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(2px);
    animation: floatUp linear infinite;
    }
    .bubble:nth-child(1)  { width:14px; height:14px; left:8%;  animation-duration:6s;  animation-delay:0s;   }
    .bubble:nth-child(2)  { width:22px; height:22px; left:18%; animation-duration:8s;  animation-delay:1.2s; }
    .bubble:nth-child(3)  { width:10px; height:10px; left:30%; animation-duration:5s;  animation-delay:0.5s; }
    .bubble:nth-child(4)  { width:18px; height:18px; left:52%; animation-duration:7s;  animation-delay:2s;   }
    .bubble:nth-child(5)  { width:26px; height:26px; left:70%; animation-duration:9s;  animation-delay:0.8s; }
    .bubble:nth-child(6)  { width:12px; height:12px; left:85%; animation-duration:6.5s;animation-delay:1.5s; }
    .bubble:nth-child(7)  { width:20px; height:20px; left:92%; animation-duration:7.5s;animation-delay:3s;   }
    .bubble:nth-child(8)  { width:8px;  height:8px;  left:44%; animation-duration:5.5s;animation-delay:0.3s; }

    @keyframes floatUp {
    0%   { bottom: -40px; opacity: 0; }
    10%  { opacity: 0.7; }
    90%  { opacity: 0.5; }
    100% { bottom: 110vh; opacity: 0; }
    }

    /* 闪光星星 */
    .star {
    position: fixed;
    width: 6px;
    height: 6px;
    background: white;
    border-radius: 50%;
    animation: twinkle ease-in-out infinite;
    }
    .star::before, .star::after {
    content: '';
    position: absolute;
    background: white;
    border-radius: 2px;
    }
    .star::before { width: 2px; height: 16px; top: -5px; left: 2px; }
    .star::after  { width: 16px; height: 2px; top: 2px; left: -5px; }

    .star:nth-child(1) { top:15%; left:12%; animation-duration:2.2s; animation-delay:0s;   }
    .star:nth-child(2) { top:25%; left:82%; animation-duration:3s;   animation-delay:0.7s; }
    .star:nth-child(3) { top:72%; left:20%; animation-duration:2.5s; animation-delay:1.4s; }
    .star:nth-child(4) { top:80%; left:75%; animation-duration:2.8s; animation-delay:0.3s; }
    .star:nth-child(5) { top:45%; left:90%; animation-duration:2s;   animation-delay:1.8s; }

    @keyframes twinkle {
    0%, 100% { opacity: 0; transform: scale(0.5) rotate(0deg); }
    50%       { opacity: 0.9; transform: scale(1.2) rotate(20deg); }
    }

    /* 主内容区 */
    .container {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    }

    /* 鸭子图片 */
    .duck-wrap {
    position: relative;
    width: 260px;
    height: 260px;
    animation: duckEntrance 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both,
    duckFloat 3.5s ease-in-out 0.8s infinite;
    }

    @keyframes duckEntrance {
    0%   { transform: scale(0) rotate(-10deg); opacity: 0; }
    100% { transform: scale(1) rotate(0deg);   opacity: 1; }
    }

    @keyframes duckFloat {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    30%       { transform: translateY(-12px) rotate(-2deg); }
    60%       { transform: translateY(-8px) rotate(1.5deg); }
    }

    .duck-shadow {
    position: absolute;
    bottom: -12px;
    left: 50%;
    transform: translateX(-50%);
    width: 160px;
    height: 18px;
    background: rgba(180, 110, 0, 0.2);
    border-radius: 50%;
    filter: blur(6px);
    animation: shadowPulse 3.5s ease-in-out 0.8s infinite;
    }

    @keyframes shadowPulse {
    0%, 100% { transform: translateX(-50%) scaleX(1);   opacity: 0.6; }
    30%       { transform: translateX(-50%) scaleX(0.75); opacity: 0.3; }
    60%       { transform: translateX(-50%) scaleX(0.85); opacity: 0.4; }
    }

    .duck-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 10%;
    border-radius: 50%;
    box-shadow:
    0 0 0 6px rgba(255, 255, 255, 0.55),
    0 0 0 10px rgba(255, 220, 80, 0.3),
    0 20px 40px rgba(180, 100, 0, 0.35);
    }

    /* 腮红装饰 */
    .blush-left, .blush-right {
    position: absolute;
    width: 50px;
    height: 28px;
    background: rgba(255, 150, 130, 0.55);
    border-radius: 50%;
    filter: blur(8px);
    animation: blushPulse 3.5s ease-in-out 0.8s infinite;
    }
    .blush-left  { bottom: 95px; left: 28px; }
    .blush-right { bottom: 95px; right: 28px; }

    @keyframes blushPulse {
    0%, 100% { opacity: 0.55; transform: scale(1); }
    50%       { opacity: 0.8;  transform: scale(1.1); }
    }

    /* 标题 */
    .title-wrap {
    margin-top: 8px;
    text-align: center;
    animation: fadeSlideUp 0.7s ease both;
    animation-delay: 0.6s;
    }

    @keyframes fadeSlideUp {
    0%   { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
    }

    .title {
    font-size: 30px;
    font-weight: 800;
    color: #7A4500;
    letter-spacing: 1px;
    text-shadow: 0 2px 0 rgba(255,255,255,0.5);
    }

    .title-cn {
    margin-top: 4px;
    font-size: 18px;
    font-weight: 700;
    color: rgba(122, 69, 0, 0.75);
    letter-spacing: 4px;
    }

    .subtitle {
    margin-top: 10px;
    font-size: 13px;
    font-weight: 500;
    color: rgba(100, 60, 0, 0.65);
    letter-spacing: 0.5px;
    line-height: 1.6;
    white-space: nowrap;
    }

    /* 金铃装饰 */
    .bell {
    margin-top: 10px;
    font-size: 22px;
    animation: bellSwing 2s ease-in-out 1.2s infinite;
    display: inline-block;
    transform-origin: top center;
    }

    @keyframes bellSwing {
    0%, 100% { transform: rotate(0deg); }
    20%       { transform: rotate(-18deg); }
    40%       { transform: rotate(14deg); }
    60%       { transform: rotate(-8deg); }
    80%       { transform: rotate(5deg); }
    }

    /* 加载条 */
    .loader-wrap {
    margin-top: 36px;
    animation: fadeSlideUp 0.7s ease both;
    animation-delay: 1s;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    }

    .loader-track {
    width: 180px;
    height: 5px;
    background: rgba(255, 255, 255, 0.35);
    border-radius: 99px;
    overflow: hidden;
    }

    .loader-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #FF8C00, #FFD700, #FF8C00);
    background-size: 200% 100%;
    border-radius: 99px;
    animation: loadFill 2.5s cubic-bezier(0.4, 0, 0.2, 1) 1.2s forwards,
    shimmer 1.5s linear 1.2s infinite;
    }

    @keyframes loadFill {
    0%   { width: 0%; }
    60%  { width: 75%; }
    100% { width: 100%; }
    }

    @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
    }

    .loader-text {
    font-size: 11px;
    color: rgba(100, 60, 0, 0.5);
    letter-spacing: 3px;
    }

    /* 底部版权 */
    .footer {
    position: fixed;
    bottom: 28px;
    font-size: 11px;
    color: rgba(100, 60, 0, 0.4);
    letter-spacing: 1px;
    animation: fadeSlideUp 0.7s ease both;
    animation-delay: 1.5s;
    z-index: 10;
    }

  </style>
</head>
<body>

  <!-- ====== 开屏页 ====== -->
  <div class="splash-screen" id="splashScreen">

  <!-- 背景 -->
  <div class="bg"></div>

  <!-- 波纹圈 -->
  <div class="ripple"></div>
  <div class="ripple"></div>
  <div class="ripple"></div>

  <!-- 浮动气泡 -->
  <div class="bubble"></div>
  <div class="bubble"></div>
  <div class="bubble"></div>
  <div class="bubble"></div>
  <div class="bubble"></div>
  <div class="bubble"></div>
  <div class="bubble"></div>
  <div class="bubble"></div>

  <!-- 闪光星 -->
  <div class="star"></div>
  <div class="star"></div>
  <div class="star"></div>
  <div class="star"></div>
  <div class="star"></div>

  <!-- 主体 -->
  <div class="container">
    <div class="duck-wrap">
      <div class="blush-left"></div>
      <div class="blush-right"></div>
      <img class="duck-img" src="data:image/png;base64," alt="玻尿酸鸭">
      <div class="duck-shadow"></div>
    </div>

    <div class="title-wrap">
      <div class="title">HappyDuck AI</div>
      <div class="title-cn">欢 乐 鸭</div>
      <div class="subtitle">像玩游戏一样轻松学习并掌握钉钉AI表格</div>
      <div class="bell">🔔</div>
    </div>

    <div class="loader-wrap">
      <div class="loader-track">
        <div class="loader-bar"></div>
      </div>
      <div class="loader-text">努力加载鸭</div>
    </div>
  </div>  </div>


  <div id="app" style="visibility:hidden;">
  </div>

  <script src="js/courses-l2.js"></script>
  <script src="js/courses-l3.js"></script>
  <script src="js/courses-l4.js"></script>
  <script src="js/courses-l5.js"></script>
  <script src="js/courses.js"></script>
  <script src="js/app.js"></script>

  <!-- 开屏页过渡控制 -->
  <script>
  (function() {
    /* JS 全部加载完成后，延迟一小段时间再淡出开屏页 */
    function dismissSplash() {
      const splash = document.getElementById('splashScreen');
      const appEl = document.getElementById('app');
      if (!splash) return;

      appEl.style.visibility = 'visible';
      splash.classList.add('fade-out');

      setTimeout(() => {
        splash.remove();
        // 新版开屏页无粒子动效，无需清理
      }, 700);
    }

    /* 确保至少展示 1.8 秒开屏页 */
    const minDisplayTime = 1800;
    const startTime = Date.now();

    if (document.readyState === 'complete') {
      const elapsed = Date.now() - startTime;
      setTimeout(dismissSplash, Math.max(0, minDisplayTime - elapsed));
    } else {
      window.addEventListener('load', function() {
        const elapsed = Date.now() - startTime;
        setTimeout(dismissSplash, Math.max(0, minDisplayTime - elapsed));
      });
    }
  })();
  </script>
</body>
</html>
