<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>HappyDuck AI 像玩游戏一样学习钉钉AI表格</title>
  <link rel="icon" type="image/png" href="favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    /* ====== 开屏页样式（暖黄色调） ====== */
    .splash-screen {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: linear-gradient(170deg, #FFF0B3 0%, #FFD54F 28%, #FFB300 60%, #F5A000 100%);
      transition: opacity 0.6s ease, transform 0.6s ease;
      overflow: hidden;
    }
    .splash-screen.fade-out {
      opacity: 0;
      transform: scale(1.05);
      pointer-events: none;
    }

    /* 粒子画布 */
    .splash-particles {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    /* 鸭子图片容器 */
    .splash-duck-wrap {
      position: relative;
      z-index: 1;
      animation: splash-duck-float 3.5s ease-in-out infinite;
    }
    @keyframes splash-duck-float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-14px); }
    }

    /* 鸭子周围的柔光 */
    .splash-glow {
      position: absolute;
      width: 440px;
      height: 440px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0) 70%);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation: splash-glow-pulse 3.5s ease-in-out infinite;
      z-index: 0;
    }
    @keyframes splash-glow-pulse {
      0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.4; }
      50% { transform: translate(-50%, -50%) scale(1.15); opacity: 0.85; }
    }

    /* 鸭子图片 */
    .splash-duck-img {
      position: relative;
      z-index: 1;
      width: 360px;
      height: 360px;
      object-fit: contain;
      filter: drop-shadow(0 12px 40px rgba(180,100,0,0.3));
    }

    /* 品牌文字 */
    .splash-brand {
      position: relative;
      z-index: 1;
      margin-top: 20px;
      text-align: center;
    }
    .splash-brand-title {
      font-family: 'Nunito', sans-serif;
      font-size: 38px;
      font-weight: 900;
      color: #FFFFFF;
      letter-spacing: -0.5px;
      text-shadow: 0 2px 24px rgba(180,100,0,0.25);
    }
    .splash-brand-sub {
      font-family: 'Nunito', 'PingFang SC', sans-serif;
      font-size: 20px;
      font-weight: 700;
      color: rgba(255,255,255,0.85);
      margin-top: 4px;
      letter-spacing: 6px;
    }

    /* 底部加载指示器 */
    .splash-loader {
      position: relative;
      z-index: 1;
      margin-top: 52px;
      display: flex;
      gap: 10px;
    }
    .splash-loader-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: rgba(255,255,255,0.55);
      animation: splash-dot-bounce 1.4s ease-in-out infinite;
    }
    .splash-loader-dot:nth-child(2) { animation-delay: 0.16s; }
    .splash-loader-dot:nth-child(3) { animation-delay: 0.32s; }
    @keyframes splash-dot-bounce {
      0%, 80%, 100% { transform: scale(0.6); opacity: 0.3; }
      40% { transform: scale(1.3); opacity: 1; }
    }
  </style>
</head>
<body>

  <!-- ====== 开屏页（暖黄版 · 原图鸭子） ====== -->
  <div class="splash-screen" id="splashScreen">
    <canvas class="splash-particles" id="splashParticles"></canvas>

    <div class="splash-duck-wrap">
      <div class="splash-glow"></div>
      <img class="splash-duck-img"
           src="images/happyduck-splash.png"
           alt="HappyDuck"
           draggable="false" />
    </div>

    <div class="splash-brand">
      <div class="splash-brand-title">HappyDuck AI</div>
      <div class="splash-brand-sub">欢乐鸭</div>
    </div>

    <div class="splash-loader">
      <div class="splash-loader-dot"></div>
      <div class="splash-loader-dot"></div>
      <div class="splash-loader-dot"></div>
    </div>
  </div>

  <!-- 暖色粒子动效脚本 -->
  <script>
  (function() {
    const canvas = document.getElementById('splashParticles');
    const ctx = canvas.getContext('2d');
    let width, height, particles, animationId;

    function resize() {
      width = canvas.width = window.innerWidth;
      height = canvas.height = window.innerHeight;
    }

    function createParticles() {
      particles = [];
      const count = Math.min(55, Math.floor(width * height / 14000));
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * width,
          y: Math.random() * height,
          radius: Math.random() * 2.8 + 0.8,
          speedX: (Math.random() - 0.5) * 0.25,
          speedY: -(Math.random() * 0.25 + 0.05),
          opacity: Math.random() * 0.45 + 0.15,
          opacitySpeed: (Math.random() - 0.5) * 0.005,
          color: ['#FFFFFF', '#FFFFFF', '#FFF9C4', '#FFF59D', '#FFFFFF'][Math.floor(Math.random() * 5)]
        });
      }
    }

    function drawParticles() {
      ctx.clearRect(0, 0, width, height);

      for (const particle of particles) {
        particle.x += particle.speedX;
        particle.y += particle.speedY;
        particle.opacity += particle.opacitySpeed;

        if (particle.opacity <= 0.08 || particle.opacity >= 0.6) {
          particle.opacitySpeed *= -1;
        }

        /* 循环：飘出顶部后从底部重新出现 */
        if (particle.y < -10) {
          particle.y = height + 10;
          particle.x = Math.random() * width;
        }
        if (particle.x < -10) particle.x = width + 10;
        if (particle.x > width + 10) particle.x = -10;

        ctx.beginPath();
        ctx.arc(particle.x, particle.y, particle.radius, 0, Math.PI * 2);
        ctx.fillStyle = particle.color;
        ctx.globalAlpha = particle.opacity;
        ctx.fill();

        /* 柔和光晕 */
        if (particle.radius > 2) {
          ctx.beginPath();
          ctx.arc(particle.x, particle.y, particle.radius * 4, 0, Math.PI * 2);
          const gradient = ctx.createRadialGradient(
            particle.x, particle.y, particle.radius * 0.5,
            particle.x, particle.y, particle.radius * 4
          );
          gradient.addColorStop(0, particle.color);
          gradient.addColorStop(1, 'transparent');
          ctx.fillStyle = gradient;
          ctx.globalAlpha = particle.opacity * 0.18;
          ctx.fill();
        }
      }

      animationId = requestAnimationFrame(drawParticles);
    }

    resize();
    createParticles();
    drawParticles();
    window.addEventListener('resize', () => { resize(); createParticles(); });

    window._stopSplashParticles = function() {
      cancelAnimationFrame(animationId);
    };
  })();
  </script>

  <div id="app" style="visibility:hidden;"></div>

  <script src="js/courses-l2.js"></script>
  <script src="js/courses-l3.js"></script>
  <script src="js/courses-l4.js"></script>
  <script src="js/courses-l5.js"></script>
  <script src="js/courses.js"></script>
  <script src="js/app.js"></script>

  <!-- 开屏页过渡控制 -->
  <script>
  (function() {
    function dismissSplash() {
      const splash = document.getElementById('splashScreen');
      const appEl = document.getElementById('app');
      if (!splash) return;

      appEl.style.visibility = 'visible';
      splash.classList.add('fade-out');

      setTimeout(() => {
        splash.remove();
        if (window._stopSplashParticles) window._stopSplashParticles();
      }, 700);
    }

    const minDisplayTime = 1800;
    const startTime = Date.now();

    if (document.readyState === 'complete') {
      const elapsed = Date.now() - startTime;
      setTimeout(dismissSplash, Math.max(0, minDisplayTime - elapsed));
    } else {
      window.addEventListener('load', function() {
        const elapsed = Date.now() - startTime;
        setTimeout(dismissSplash, Math.max(0, minDisplayTime - elapsed));
      });
    }
  })();
  </script>
</body>
</html>
